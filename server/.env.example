PORT=3333
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/finflow
# Valores exclusivos para evaluación local. Reemplazarlos por secretos largos y aleatorios en producción.
JWT_ACCESS_SECRET=finflow-evaluacion-local-access-cambiar-en-produccion
JWT_REFRESH_SECRET=finflow-evaluacion-local-refresh-cambiar-en-produccion
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:8082
GEMINI_API_KEY=
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_PAYMENT_REMINDER=
WHATSAPP_TEMPLATE_WEEKLY_SUMMARY=
SAMPLE_USER_EMAIL=usuario@gmail.com
SAMPLE_USER_PASSWORD=Usuario.123
