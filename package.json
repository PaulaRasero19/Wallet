{
  "name": "finflow",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev": "concurrently -k -n server,mobile \"npm run dev:server\" \"npm run dev:mobile\"",
    "dev:mobile": "REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 expo start --android",
    "dev:server": "npm run dev --prefix server",
    "backend": "npm run dev:server",
    "ai-server": "node server/ai-server.js",
    "server:build": "npm run build --prefix server",
    "server:start": "npm run start --prefix server",
    "server:test": "npm run test --prefix server",
    "server:seed:demo": "npm run seed:demo --prefix server",
    "server:seed:sample-user": "npm run seed:sample-user --prefix server",
    "apk": "cd android && NODE_ENV=development ./gradlew assembleDebug",
    "apk:release": "cd android && NODE_ENV=production ./gradlew assembleRelease",
    "typecheck": "tsc --noEmit && npm run typecheck --prefix server",
    "lint": "npm run lint --prefix server"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@shopify/react-native-skia": "v2.0.0-next.4",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.1.6",
    "expo-font": "~13.3.2",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.2",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "lucide-react-native": "^1.25.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.0.10",
    "concurrently": "^10.0.3",
    "typescript": "~5.8.3"
  }
}
